# Copy this file to .env and fill in your own Supabase credentials.
# Do NOT commit real keys to version control.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key-keep-secret

# Optional: email delivery via Brevo REST API
# BREVO_API_KEY=your-brevo-api-key
# BREVO_SENDER_NAME=CatequesePRO
# BREVO_SENDER_EMAIL=no-reply@example.com

# Optional: CLI auth token for supabase CLI (for remote operations)
# SUPABASE_ACCESS_TOKEN=your-supabase-cli-access-token

# Optional: Gemini API Key for Ideias IA page (legacy)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Groq API Key for Ideias IA page (get yours at https://console.groq.com)
VITE_GROK_API_KEY=your-groq-api-key

